# Fortune & Ruin — Required Environment Variables
# Copy this file to .env and fill in your values
# (or add these to your system environment / GitHub Secrets)

# ── REQUIRED ─────────────────────────────────────────────────────────────────

# Anthropic API — for hook jury, script generation, idea synthesis, X content
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── FOR IDEA GENERATION ───────────────────────────────────────────────────────

# YouTube Data API v3 (free, Google Cloud)
# Setup: console.cloud.google.com → New Project → Enable YouTube Data API v3
# → Create Credentials → API Key → Restrict to YouTube Data API v3
YOUTUBE_API_KEY=your_youtube_api_key_here

# Reddit is accessed without credentials (public JSON API, read-only)
# No setup needed unless you hit rate limits — then register a script app at
# reddit.com/prefs/apps and add:
# REDDIT_CLIENT_ID=your_reddit_client_id
# REDDIT_CLIENT_SECRET=your_reddit_client_secret

# ── FOR X (TWITTER) AUTO-POSTING (deferred — set up when ready) ──────────────
# X Developer Portal: developer.twitter.com → Projects & Apps → New App
# Free tier: 500 posts/month
# X_API_KEY=
# X_API_SECRET=
# X_ACCESS_TOKEN=
# X_ACCESS_TOKEN_SECRET=
# X_BEARER_TOKEN=

# ── FOR EMAIL ALERTS (already set in GitHub Secrets for e-commerce) ──────────
# GMAIL_ADDRESS=muneebnaseem786@gmail.com
# GMAIL_APP_PASSWORD=your_gmail_app_password
